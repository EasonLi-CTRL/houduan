generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  password  String
  storeName String
  createdAt DateTime @default(now())
  leads     Lead[]
  followUps FollowUp[]
}

model Community {
  id              Int      @id @default(autoincrement())
  name            String
  address         String
  deliveryYear    Int
  totalHouseholds Int
  lat             Float
  lng             Float
  status          String   @default("交房不久")
  createdAt       DateTime @default(now())
  leads           Lead[]
}

model Lead {
  id                Int        @id @default(autoincrement())
  name              String
  phone             String
  communityId       Int
  community         Community  @relation(fields: [communityId], references: [id])
  houseType         String     @default("")
  area              Float      @default(0)
  intendedProduct   String     @default("")
  budget            Float      @default(0)
  source            String     @default("门店进店")
  intentionLevel    String     @default("C")
  status            String     @default("new")
  remark            String     @default("")
  nextFollowUpAt    DateTime?
  creatorId         Int
  creator           User       @relation(fields: [creatorId], references: [id])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  followUps         FollowUp[]
  referralsAsLead   Referral[] @relation("LeadReferral")
}

model FollowUp {
  id         Int      @id @default(autoincrement())
  leadId     Int
  lead       Lead     @relation(fields: [leadId], references: [id])
  content    String
  type       String   @default("phone")
  createdAt  DateTime @default(now())
  followerId Int
  follower   User     @relation(fields: [followerId], references: [id])
}

model Product {
  id          Int      @id @default(autoincrement())
  category    String   @default("木门")
  name        String
  model       String   @default("")
  priceRange  String   @default("")
  imageUrl    String   @default("")
  description String   @default("")
  createdAt   DateTime @default(now())
}

model Referral {
  id            Int      @id @default(autoincrement())
  referrerName  String
  referrerPhone String
  leadId        Int
  lead          Lead     @relation("LeadReferral", fields: [leadId], references: [id])
  rewardAmount  Float    @default(0)
  status        String   @default("pending")
  createdAt     DateTime @default(now())
}